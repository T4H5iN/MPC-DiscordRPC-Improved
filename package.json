{
  "name": "MPC-DiscordRPC",
  "version": "1.0.0",
  "description": "Discord Rich Presence for Media Player Classic with TMDB integration",
  "main": "main.js",
  "author": "angeloanan <anandavid2002@gmail.com>",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.mpc-discordrpc.app",
    "productName": "MPC-DiscordRPC",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    }
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.7.3",
    "fancy-log": "^2.0.0",
    "jsdom": "^22.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}